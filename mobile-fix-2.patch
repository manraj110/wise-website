diff --git a/src/app/globals.css b/src/app/globals.css
index 6c9d0c9..5778419 100644
--- a/src/app/globals.css
+++ b/src/app/globals.css
@@ -394,4 +394,134 @@ body {
   }
   /* Re-allow px-8 on sections that already have it — those use 2rem,
      our 1.25rem override is tighter which is what we want on a phone */
+
+  /* ------------------------------------------------------------------
+     OUR SERVICES — interactive showcase card
+     Problem this solves: each of the 8 service panels is a fixed
+     780x560px "canvas" built entirely from absolutely-positioned
+     children with hard-coded pixel offsets (icons, headings,
+     descriptions). On a phone the card itself shrinks to ~300-340px
+     wide, but the *content inside* doesn't — the icon row, the 5-up
+     grid of titles, the heading, etc. all stay sized for a 780px-wide
+     box, so they overlap and run off the edge (this is exactly the
+     "DOCUMENTATION / INFRASTRUCTURE READINESS" overlapping text bug).
+     Rewriting all 8 hand-built diagrams individually would risk
+     breaking the desktop version of each one.
+     Fix: pin the canvas back to its native 780x560 design size, then
+     shrink it as a whole using `zoom` (not `transform`, which would
+     leave dead space below it — `zoom` shrinks the box for layout
+     purposes too, so the card after it just sits closer with no gap).
+     `zoom: calc(...)` scales continuously with viewport width; the
+     plain `zoom: 0.4` line right before it is a safe fallback for the
+     rare browser that doesn't support length-by-length division in
+     calc() — it's overridden by the calc() line wherever calc() is
+     understood for zoom.
+     ------------------------------------------------------------------ */
+  .service-card-canvas {
+    margin-right: 0 !important;
+    width: 780px !important;
+    max-width: none !important;
+    flex-shrink: 0 !important;
+    zoom: 0.4;
+    zoom: calc((100vw - 40px) / 780px);
+  }
+
+  /* ------------------------------------------------------------------
+     OUR SERVICES — carousel controls (Learn More + dots/arrows)
+     Problem this solves: on desktop the dots/arrows are pushed
+     384px (marginLeft: 24rem) to the right to sit under the wide
+     showcase card. On a narrow phone that pushes them completely
+     off-screen, so the slide indicator and prev/next buttons are
+     invisible and unusable.
+     Fix: stack Learn More above the dots/arrows, both left-aligned.
+     ------------------------------------------------------------------ */
+  .service-controls-row {
+    flex-direction: column !important;
+    align-items: flex-start !important;
+    gap: 1.25rem !important;
+    margin-top: 1.5rem !important;
+  }
+  .service-nav-dots {
+    margin-left: 0 !important;
+    margin-top: 0 !important;
+  }
+
+  /* ------------------------------------------------------------------
+     STAT CARDS — Growth Journey / Service Portfolio / Institutions
+     Served. Each has a fixed marginRight: 2rem (eating into already
+     tight phone width) plus generous fixed padding.
+     ------------------------------------------------------------------ */
+  .stat-card-mobile {
+    margin-right: 0 !important;
+    padding: 20px !important;
+  }
+
+  /* Service Portfolio donut chart + legend: stack chart above the
+     legend instead of side-by-side, so percentage labels have the
+     card's full width instead of a squeezed leftover sliver. */
+  .portfolio-piechart-row {
+    flex-direction: column !important;
+    align-items: stretch !important;
+    gap: 1.25rem !important;
+  }
+
+  /* ------------------------------------------------------------------
+     WHY SCHOOLS CHOOSE US — flip cards
+     Problem this solves: badge (60px) sits absolutely at top-left,
+     and the content block below it uses a fixed 80px top padding to
+     clear it — both sized for a wide desktop card. On a narrow phone
+     card the same fixed padding/heading size crowds the badge and
+     makes the heading wrap awkwardly into it.
+     ------------------------------------------------------------------ */
+  .flip-card-badge {
+    width: 44px !important;
+    height: 44px !important;
+    top: 1.1rem !important;
+    left: 1.1rem !important;
+    font-size: 1.05rem !important;
+  }
+  .flip-card-content {
+    padding: 4rem 1.5rem 1.5rem 1.5rem !important;
+  }
+  .flip-card-content h3 {
+    font-size: 1.6rem !important;
+  }
+  .flip-card-content p {
+    font-size: 1rem !important;
+  }
+
+  /* ------------------------------------------------------------------
+     EDGE-MARGIN CARDS — success-story card, contact card, footer grid.
+     All three carry a fixed marginLeft/marginRight: 2rem (32px each
+     side) which, stacked on top of the 1.25rem section padding above,
+     leaves very little width for content on a phone.
+     ------------------------------------------------------------------ */
+  .edge-margin-2rem {
+    margin-left: 0  !important;
+    margin-right: 0 !important;
+  }
+
+  /* Success-story card: right-hand content padding shrunk so the
+     heading/paragraph/stats aren't fighting a 48px side padding on
+     top of the squeeze above. */
+  .success-card-content {
+    padding: 2rem 1.5rem !important;
+  }
+
+  /* Contact section: both panels use a fixed 48px padding; reduce it,
+     and stop the two phone numbers from sitting side-by-side (they
+     were overflowing past the edge of the screen) — stack them and
+     hide the "|" separator that only makes sense inline. */
+  .contact-left-panel,
+  .contact-right-panel {
+    padding: 1.75rem 1.25rem !important;
+  }
+  .contact-phone-row {
+    flex-direction: column !important;
+    align-items: flex-start !important;
+    gap: 0.25rem !important;
+  }
+  .contact-phone-sep {
+    display: none !important;
+  }
 }
