diff --git a/src/app/globals.css b/src/app/globals.css
index f79b55e..488d593 100644
--- a/src/app/globals.css
+++ b/src/app/globals.css
@@ -93,6 +93,45 @@ html {
   scroll-padding-top: 100px;
 }
 
+/* ===================================================================
+   FLUID HEADING SIZES
+   Problem this solves: headings used a fixed huge size for every screen
+   >=768px (e.g. text-5xl md:text-[5.4rem]), so a 1366px laptop got the
+   exact same 86px text as a 1920px+ monitor. Relative to a narrower
+   screen that's much bigger, which is why the page felt "zoomed in" on
+   smaller laptops even though it looked fine on a larger one.
+   clamp() scales the size smoothly with viewport width instead of
+   jumping at one breakpoint, so it self-adjusts on any screen size.
+   ================================================================ */
+.heading-fluid-lg {
+  font-size: clamp(3rem, 2.15rem + 3.38vw, 5.4rem);
+  font-weight: 700;
+  line-height: 1.1;
+  letter-spacing: -0.05em;
+}
+.heading-fluid-md {
+  font-size: clamp(3rem, 2.3rem + 2.82vw, 5rem);
+  font-weight: 700;
+  line-height: 1.08;
+  letter-spacing: -0.04em;
+}
+.heading-fluid-sm {
+  font-size: clamp(3rem, 2.44rem + 2.25vw, 4.6rem);
+  font-weight: 700;
+  line-height: 1.1;
+  letter-spacing: -0.05em;
+}
+.heading-fluid-stat {
+  font-size: clamp(4.5rem, 4.15rem + 1.41vw, 5.5rem);
+  font-weight: 700;
+  line-height: 1;
+}
+.heading-fluid-xs {
+  font-size: clamp(1.5rem, 1.25rem + 0.99vw, 2.2rem);
+  font-weight: 700;
+  line-height: 1.15;
+}
+
 /* Used by HashScrollFix: hides the page while it settles the scroll
    position for a cross-page hash link, then fades it back in. */
 body.hash-settling {
